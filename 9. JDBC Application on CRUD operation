import java.sql.*;
public class RestaurantJDBC {
    static final String URL = "jdbc:mysql://localhost:3306/restaurantdb";
    static final String USER = "root";
    static final String PASS = "password";
    public static void main(String[] args) {
        try (Connection con = DriverManager.getConnection(URL, USER, PASS)) {
            createTables(con);
            insertRecords(con);
            selectMenuItemsUnder100(con);
            selectMenuItemsByCafeJava(con);
            updatePriceUnder100(con);
            deleteItemsStartingWithP(con);
        } catch (SQLException e) {
            e.printStackTrace();
        }
    }
    // 
 Create Tables 
    static void createTables(Connection con) throws SQLException {
        Statement st = con.createStatement();
        st.executeUpdate("DROP TABLE IF EXISTS MenuItem");
        st.executeUpdate("DROP TABLE IF EXISTS Restaurant");
        st.executeUpdate(
            "CREATE TABLE Restaurant (" +
            "Id INT PRIMARY KEY, Name VARCHAR(50), Address VARCHAR(100))");
        st.executeUpdate(
            "CREATE TABLE MenuItem (" +
            "Id INT PRIMARY KEY, Name VARCHAR(50), " +
            "Price DOUBLE, ResId INT, " +
            "FOREIGN KEY (ResId) REFERENCES Restaurant(Id))");
        System.out.println("Tables created successfully.");
    }
    // 
 Insert 10 Records in Each Table 
    static void insertRecords(Connection con) throws SQLException {
        Statement st = con.createStatement();
        // Insert 10 Restaurants
        String[][] restaurants = {
            {"1", "Cafe Java", "12 MG Road, Pune"},
            {"2", "Spice Garden", "45 FC Road, Pune"},
            {"3", "The Diner", "78 Camp, Pune"},
            {"4", "Pizza Palace", "22 JM Road, Pune"},
            {"5", "Burger Barn", "5 Baner, Pune"},
            {"6", "Noodle House", "33 Kothrud, Pune"},
            {"7", "Sushi World", "9 Aundh, Pune"},
            {"8", "Taco Town", "88 Wakad, Pune"},
            {"9", "Biryani Bros", "11 Hadapsar, Pune"},
            {"10","Waffle Corner", "67 Viman Nagar, Pune"}
        };
        for (String[] r : restaurants) {
            st.executeUpdate("INSERT INTO Restaurant VALUES(" +
                r[0] + ",'" + r[1] + "','" + r[2] + "')");
        }
        System.out.println("10 Restaurant records inserted.");
        // Insert 10 MenuItems
        String[][] items = {
            {"1", "Pasta", "80", "1"},
            {"2", "Coffee", "60", "1"},
            {"3", "Paneer Tikka", "150", "2"},
            {"4", "Butter Naan", "40", "2"},
            {"5", "Club Sandwich", "120", "3"},
            {"6", "Pepperoni Pizza","200","4"},
            {"7", "Veg Burger", "90", "5"},
            {"8", "Hakka Noodles", "100", "6"},
            {"9", "Salmon Roll", "250", "7"},
            {"10", "Waffle Cone", "75", "10"}
        };
        for (String[] m : items) {
            st.executeUpdate("INSERT INTO MenuItem VALUES(" +
                m[0] + ",'" + m[1] + "'," + m[2] + "," + m[3] + ")");
        }
        System.out.println("10 MenuItem records inserted.");
    }
    // 
 Print ResultSet as Table 
    static void printResultSet(ResultSet rs) throws SQLException {
        ResultSetMetaData md = rs.getMetaData();
        int cols = md.getColumnCount();
        // Print header
        for (int i = 1; i <= cols; i++)
            System.out.printf("%-20s", md.getColumnName(i));
        System.out.println();
        System.out.println("-".repeat(cols * 20));
        // Print rows
        while (rs.next()) {
            for (int i = 1; i <= cols; i++)
                System.out.printf("%-20s", rs.getString(i));
            System.out.println();
        }
        System.out.println();
    }
    // 
 SELECT: MenuItem where price <= 100 
    static void selectMenuItemsUnder100(Connection con) throws SQLException {
        System.out.println("\n[SELECT] MenuItem where Price <= 100:");
        String sql = "SELECT * FROM MenuItem WHERE Price <= 100";
        ResultSet rs = con.createStatement().executeQuery(sql);
        printResultSet(rs);
    }
    // 
 SELECT: MenuItem from 'Cafe Java' 
    static void selectMenuItemsByCafeJava(Connection con) throws SQLException {
        System.out.println("[SELECT] MenuItem available in 'Cafe Java':");
        String sql = "SELECT m.* FROM MenuItem m " +
                     "JOIN Restaurant r ON m.ResId = r.Id " +
                     "WHERE r.Name = 'Cafe Java'";
        ResultSet rs = con.createStatement().executeQuery(sql);
        printResultSet(rs);
    }
    //  UPDATE: price <= 100 → price = 200 
    static void updatePriceUnder100(Connection con) throws SQLException {
        String sql = "UPDATE MenuItem SET Price = 200 WHERE Price <= 100";
        int rows = con.createStatement().executeUpdate(sql);
        System.out.println("[UPDATE] Rows updated (Price <= 100 -> 200): " + rows);
        System.out.println("[SELECT] MenuItem after update:");
        ResultSet rs = con.createStatement().executeQuery("SELECT * FROM MenuItem");
        printResultSet(rs);
    }
    //  DELETE: MenuItem where Name starts with 'P' 
    static void deleteItemsStartingWithP(Connection con) throws SQLException {
        String sql = "DELETE FROM MenuItem WHERE Name LIKE 'P%'";
        int rows = con.createStatement().executeUpdate(sql);
        System.out.println("[DELETE] Rows deleted (Name starts with P): " + rows);
        System.out.println("[SELECT] MenuItem after delete:");
        ResultSet rs = con.createStatement().executeQuery("SELECT * FROM MenuItem");
        printResultSet(rs);
    }
}
